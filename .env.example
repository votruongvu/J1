# Local-development environment for the J1 stack.
#
# Copy to `.env` (which is git-ignored) before running `docker compose up`:
#
#     cp .env.example .env
#
# Variable names match the framework's existing `J1_*` convention — all
# settings live in one namespace so it's clear what comes from J1 vs.
# the deployment. Do not put real secrets here; this file is committed.

# ---- Workspace ------------------------------------------------------
# Where every project's data lives on disk. Inside the container the
# workspace is mounted at this path; on the host it lives in the
# named Docker volume `j1_workspace` (see deploy/dev/docker-compose.yml).
J1_DATA_ROOT=/var/lib/j1

# ---- Temporal -------------------------------------------------------
# Temporal connection used by both the API (workflow start / query)
# and the worker (workflow + activity registration).
J1_TEMPORAL_TARGET=temporal:7233
J1_TEMPORAL_NAMESPACE=default
J1_TEMPORAL_TASK_QUEUE=j1-processing
# J1_TEMPORAL_TLS=false
# J1_TEMPORAL_API_KEY=...

# Host port the Temporal Web UI is published on. Compose maps the
# container's :8080 to this host port. The Temporal UI's CORS origin
# derives from the same value, so changing this here flips both
# halves at once.
# J1_TEMPORAL_UI_PORT=8080

# ---- API service ----------------------------------------------------
# Port the FastAPI app binds to inside the container. Mapped to the
# same host port by the compose file.
J1_API_PORT=8000

# Optional version string surfaced via `GET /version`. Defaults to
# `0.0.1-dev` when unset. Operators typically inject the build SHA.
# J1_API_VERSION=0.0.1-dev

# Maximum bytes per multipart upload. The intake service enforces
# this during the streaming copy and raises 413 once the cap is
# crossed, so a runaway client can't fill the workspace volume.
# Defaults to 200 MiB to match the FE's stated cap.
# J1_MAX_UPLOAD_BYTES=209715200

# Comma-separated allow-list of upload filename extensions (with or
# without leading dot, case-insensitive). The intake service rejects
# anything outside the list with 415. Defaults cover the document
# types the bundled pipeline can process:
# .pdf, .docx, .doc, .xlsx, .xls, .csv, .ods, .html, .htm, .txt,
# .md, .markdown, .rst, .log
# Set to `*` to disable the boundary (operator opt-out).
# J1_ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.txt,.md

# Preserve MinerU's per-document intermediate output directory
# after a SUCCESSFUL compile. Defaults to off — successful compiles
# delete `<workdir>/outputs/<document_id>` after the bridge has
# walked it for ArtifactDrafts. Set to `true` only when actively
# debugging a successful parse (e.g. inspecting MinerU's intermediate
# layout / OCR images). Failed compiles ALWAYS preserve their
# output dir regardless of this flag.
# J1_KEEP_FAILED_INGEST_ARTIFACTS=false

# Suppress the startup WARN that fires when J1_AUTH_API_KEYS is
# unset — i.e. when admin endpoints (POST /projects, review
# decisions, ingestion-job control signals) run anonymously. Set
# this only in dev / ephemeral stacks where insecure-default is
# acceptable. Production deployments should set J1_AUTH_API_KEYS
# instead and leave this unset.
# J1_ALLOW_ANONYMOUS_ADMIN=1

# ---- Frontend service ----------------------------------------------
# Host port the J1 Execution Console SPA is published on. Inside the
# container nginx serves on :80; compose maps it to this host port.
J1_FRONTEND_PORT=8081

# Base URL the SPA points at on first load — baked into the static
# bundle at build time via Vite's `VITE_API_BASE_URL`. The default
# `/api` keeps the browser single-origin (nginx in the frontend
# container proxies `/api/*` to `api:8000`), so the backend doesn't
# need a CORS allow-list. Override to an absolute URL when shipping
# the bundle to a host that doesn't proxy the API on the same origin
# (staging, production, …):
#
#   J1_FRONTEND_API_BASE_URL=https://api.your-deploy.example.com
#
# Users can still override per-browser via the Authorize modal — this
# only sets the default that ships in the bundle.
# J1_FRONTEND_API_BASE_URL=/api

# ---- Worker service -------------------------------------------------
# Maximum number of activities a single worker process runs in
# parallel. Tune to taste; defaults to a small number for laptop use.
J1_WORKER_MAX_CONCURRENT_ACTIVITIES=5

# ---- Auth (optional — empty disables authentication) ----------------
# When unset, the API runs in anonymous mode (every request gets the
# anonymous SecurityContext). For local development that's fine.
# To require auth, set to a JSON object keyed by token:
#
#   J1_AUTH_API_KEYS={"kb_local_001":{"subject":"dev","tenant_id":"acme","scopes":["kb:read","kb:search","kb:answer","kb:ingest","kb:admin","kb:audit.read"]}}
#
# Or point at a JSON file:
#
#   J1_AUTH_API_KEYS_FILE=/run/secrets/j1-api-keys.json
#
# Never put real keys in this committed file.

# ---- Webhooks (optional) -------------------------------------------
# Inline list, or a path to a JSON file with the same shape:
# J1_WEBHOOK_SUBSCRIPTIONS_FILE=/run/secrets/j1-webhooks.json

# ---- Event publisher (optional) ------------------------------------
# Defaults to `noop` — enable `bus` to fan events to webhook subscribers.
# J1_EVENT_PUBLISHER_TYPE=bus

# ---- Processing pipeline selection ---------------------------------
# Compiler → Enrich → Graph → Persist. Each stage is selected
# independently. Built-in selections:
#
#   mock         — bundled deterministic mock adapters; no vendor
#                  deps, no LLM credentials required. Used by the dev
#                  Docker stack so `docker compose up` runs a real
#                  workflow end-to-end out of the box.
#   raganything  — production-grade RAGAnything provider; requires
#                  `pip install j1[raganything]` AND the J1_TEXT_LLM_*
#                  / J1_EMBEDDING_* (and J1_VISION_LLM_* if visual
#                  enrichment is on) env vars below.
#   graphify     — alternative graph provider (graph stage only);
#                  also requires J1_GRAPHIFY_ENABLED=true.
#
# Defaults below run a deterministic smoke pipeline. Flip to
# `raganything` once you've configured an LLM endpoint.
J1_DEFAULT_COMPILER=mock
J1_DEFAULT_GRAPH_PROVIDER=mock
J1_DEFAULT_RETRIEVAL_PROVIDER=mock

# Production-grade selections (commented out — uncomment + set the
# LLM env vars further down to drive real processing):
# J1_DEFAULT_COMPILER=raganything
# J1_DEFAULT_GRAPH_PROVIDER=raganything
# J1_DEFAULT_RETRIEVAL_PROVIDER=raganything

# ---- Enrichment ----------------------------------------------------
# Confidence-driven enrichment between Compiler and Graph stages.
# Disabled by default in the dev stack — there are no bundled mock
# enrichers. To run enrichment, register your own enricher map in a
# forked worker entrypoint and set J1_ENRICH_ENABLED=true.
# Visual modalities (images / diagrams / scanned pages) additionally
# require the vision LLM role to be configured below.
J1_ENRICH_ENABLED=false
J1_ENRICH_CONFIDENCE_THRESHOLD=0.75
J1_ENRICH_IMAGES=true
J1_ENRICH_TABLES=true
J1_ENRICH_DIAGRAMS=true
J1_ENRICH_SCANNED_PAGES=true

# ---- RAGAnything provider ------------------------------------------
J1_RAGANYTHING_MODE=local
# Where RAGAnything / LightRAG persists its working state (the
# `kv_store_*.json` files, MinerU's per-document outputs, the
# embedding cache). Default points inside the j1_workspace
# named volume so:
#   * state survives container recreation (`docker compose up --build`),
#   * I/O lands in the Linux VM's overlay disk, NOT a macOS bind mount —
#     critical on Apple Silicon where bind-mounted FUSE writes are
#     ~10x slower than named-volume writes,
#   * the workspace area's existing per-tenant scoping continues to
#     apply (audit / runs / artifacts already live under J1_DATA_ROOT).
# Override to `./data/raganything` only if you intentionally want
# the workdir on the host (e.g. for offline inspection).
J1_RAGANYTHING_WORKDIR=/var/lib/j1/raganything
# Defaults to WORKDIR itself when unset — LightRAG writes
# `kv_store_*.json` files directly into working_dir (not into a
# `storage` subdirectory). Override only if your deployment uses
# a non-default LightRAG layout.
# J1_RAGANYTHING_STORAGE_DIR=/var/lib/j1/raganything
# J1_RAGANYTHING_CACHE_DIR=/var/lib/j1/raganything/cache
#
# Pipeline mode — controls whether the compile activity calls the
# legacy single-shot `process_document_complete` or the new split
# `parse_document` + `insert_content_list` boundary.
#
# Valid:
#   complete             — legacy default. parse + chunk + index in
#                          one indivisible activity.
#   split_parse_insert   — RECOMMENDED for new deployments. The
#                          compile activity stops after parsing
#                          and persists a `parsed_source` artifact
#                          + manifest with real items[]; a separate
#                          `insert_content` step (after the
#                          Execution Plan is in hand) calls
#                          `insert_content_list` to drive chunking
#                          + LightRAG indexing. Auto-falls back to
#                          `complete` if the installed RAGAnything
#                          version doesn't expose the methods.
#
# Default unset = complete (backward compat). Flip to
# `split_parse_insert` when you want Content Inventory + Execution
# Plan to surface before chunking starts.
# J1_RAGANYTHING_PIPELINE_MODE=split_parse_insert
#
# MinerU PDF parse method (CLI flag -m / --method).
# Valid: auto, txt, ocr. Default `auto` lets MinerU pick per page.
# J1_RAGANYTHING_PARSE_METHOD=auto
#
# MinerU inference backend (CLI flag -b / --backend).
# Valid: pipeline, vlm-http-client, hybrid-http-client,
#        vlm-auto-engine, hybrid-auto-engine.
# Default (unset) lets MinerU pick its own — typically
# `hybrid-auto-engine`, which needs local torch + GPU.
#
# Set `vlm-http-client` to offload VLM inference to an OpenAI-compat
# endpoint. Strongly recommended for laptops without GPU passthrough —
# local CPU inference takes ~5 min/page; routing to a hosted endpoint
# typically drops it to seconds.
#
# IMPORTANT: the endpoint must serve a MinerU-compatible VLM that
# returns the layout-extraction protocol — not a generic conversational
# model. A general chat VLM (Gemma, generic LLaVA, etc.) will reply with
# prose; MinerU's parser logs `Layout output does not match expected
# format`, drops every page, and surfaces the error as
# `Parsing failed: No content was extracted`.
#
# Known-good models: opendatalab/MinerU2.5-Pro-2604-1.2B (canonical),
# served via vLLM or sglang. LM Studio's GGUF catalog does not currently
# carry a MinerU-trained VLM, so for vlm-http-client either run vLLM
# alongside LM Studio (different port) or switch
# J1_RAGANYTHING_BACKEND=pipeline (no VLM needed; uses the traditional
# CV detectors and downloads ~2.4 GB of weights into the worker's HF
# cache on first compile).
# J1_RAGANYTHING_BACKEND=vlm-http-client
#
# When backend=vlm-http-client, the bridge propagates these into
# MinerU's `MINERU_VL_SERVER` / `MINERU_VL_API_KEY` /
# `MINERU_VL_MODEL_NAME` env vars at compile time. Defaults fall
# through to the project-wide `J1_VISION_LLM_*` config above —
# turning vlm-http-client on requires ONLY the backend flag,
# nothing else. Override these explicitly to point MinerU at a
# different VLM than the rest of the stack uses.
# J1_RAGANYTHING_VLM_HTTP_SERVER_URL=http://host.docker.internal:1234/v1
# J1_RAGANYTHING_VLM_HTTP_API_KEY=lm-studio
# J1_RAGANYTHING_VLM_HTTP_MODEL_NAME=google/gemma-4-e4b
#
# Processor hooks — point at deployment-supplied callables that drive
# the actual `raganything` library. When set, the adapter loads them
# via the safe class-loader (allowlisted to langchain*, j1.*, plus
# any prefix you register via j1.register_trusted_prefix).
# Format: "module.path:callable_name" or "module.path.callable_name".
# J1_RAGANYTHING_COMPILER_PROCESSOR=mypkg.processors:compile_doc
# J1_RAGANYTHING_GRAPH_PROCESSOR=mypkg.processors:build_graph
# J1_RAGANYTHING_RETRIEVAL_PROCESSOR=mypkg.processors:query
#
# LibreOffice pre-conversion (broad document-format coverage).
# RAGAnything / mineru parses PDF + modern OOXML (.docx/.xlsx/.pptx)
# + images natively, but cannot parse legacy binary office formats
# (.doc/.xls/.ppt), OpenDocument (.odt/.ods/.odp), Rich Text (.rtf),
# Apple iWork (.pages/.numbers/.key), or Microsoft Works (.wps).
# For those, the bridge calls `soffice --headless --convert-to pdf
# <source>` and feeds the resulting PDF to raganything.
#
# Comma-separated extension list (with or without leading dot).
# Set empty to disable conversion entirely. Default covers the
# common legacy / non-OOXML formats:
# J1_RAGANYTHING_PDF_CONVERT_EXTENSIONS=.doc,.xls,.ppt,.rtf,.odt,.ods,.odp,.pages,.numbers,.key,.wps
#
# LibreOffice headless binary. Default `soffice`; some distros use
# `libreoffice` as the user-facing alias. Resolved via $PATH.
# J1_RAGANYTHING_LIBREOFFICE_BINARY=soffice
#
# Per-conversion timeout (seconds). LibreOffice can be slow on first
# launch (font cache rebuild). Default 120s.
# J1_RAGANYTHING_LIBREOFFICE_TIMEOUT_SECONDS=120

# ---- Graphify provider (optional alternative graph builder) --------
J1_GRAPHIFY_ENABLED=false
J1_GRAPHIFY_MODE=cli
J1_GRAPHIFY_COMMAND=graphify
J1_GRAPHIFY_WORKDIR=./data/graphify
# Processor hook (same format as RAGAnything):
# J1_GRAPHIFY_GRAPH_PROCESSOR=mypkg.processors:graphify_build

# ---- LLM roles (text / vision / embedding) -------------------------
# Three roles, configured independently. `openai_compat` works with
# any provider that exposes the OpenAI REST surface (vLLM, Ollama,
# Together, Azure, DashScope, etc.). For LangChain, set the role's
# *_PROVIDER to `langchain` and supply a JSON config — see
# docs/architecture.md § "LLM provider layer".
#
# `*_BASE_URL` shape — INCLUDE the version segment, OMIT the leaf:
#   OpenAI       https://api.openai.com/v1
#   Together     https://api.together.xyz/v1
#   DashScope    https://dashscope.aliyuncs.com/compatible-mode/v1
#   vLLM         http://<host>:<port>/v1
#   Ollama       http://<host>:11434/v1
#   Azure OpenAI https://<resource>.openai.azure.com/openai/deployments/<deployment>
# The framework appends `/chat/completions` or `/embeddings` itself.
# Pasting the full leaf (e.g. `…/v1/chat/completions`) is tolerated —
# the framework strips it. Omitting `/v1` entirely produces an HTTP 404
# whose error message names both the configured base_url and the URL
# we tried, so misconfiguration is easy to spot.
#
# Startup connectivity probe. Default `true`: probes every configured
# TEXT / FAST / EMBEDDING role at boot, caches results for `/healthz/llm`,
# and starts a background daemon that re-probes on a bounded interval
# (default 30s) so the cached state stays fresh as the LLM endpoint
# goes up/down. Probe failures are warn-only — server still boots.
# Set `false` for tests + mock-only deployments.
# J1_LLM_STARTUP_PROBE=true
#
# Per-probe-call deadline. The configured client timeouts are sized
# for real generation (often 5+ minutes); the startup + background
# probe needs a much shorter deadline so an unreachable LLM doesn't
# block server startup. Default 5 seconds.
# J1_LLM_PROBE_TIMEOUT_SECONDS=5
#
# Background re-probe interval. The cached health snapshot is
# refreshed on this cadence so the FE banner clears within ~30s of
# the operator fixing the LLM. Set to 0 to disable the background
# monitor (only the startup probe runs).
# J1_LLM_HEALTH_MONITOR_INTERVAL_SECONDS=30

# Text LLM
J1_TEXT_LLM_PROVIDER=openai_compat
J1_TEXT_LLM_BASE_URL=
J1_TEXT_LLM_API_KEY=
J1_TEXT_LLM_MODEL=
J1_TEXT_LLM_TIMEOUT_SECONDS=60
J1_TEXT_LLM_MAX_RETRIES=3
J1_TEXT_LLM_TEMPERATURE=0.2
J1_TEXT_LLM_MAX_OUTPUT_TOKENS=4096
# Token-budget enforcement (defends against LM Studio / OpenAI's
# "Context size has been exceeded" HTTP 400). When set, J1
# pre-flights every chat-completion request and raises a typed
# `LLMContextOverflowError` BEFORE the HTTP call when the
# estimated prompt would overflow.
#
#     available_input_tokens =
#         CONTEXT_WINDOW_TOKENS
#         - MAX_OUTPUT_TOKENS
#         - SAFETY_MARGIN_TOKENS
#
# Set CONTEXT_WINDOW_TOKENS to the model's actual window
# (e.g. 4096 for a 4K-window local model, 32768 for Llama-3.1-8B
# in 32K mode). Leave unset to disable the check (legacy /
# don't-know-the-window deployments).
# J1_TEXT_LLM_CONTEXT_WINDOW_TOKENS=8192
# J1_TEXT_LLM_SAFETY_MARGIN_TOKENS=256
# For LangChain: provide an inline JSON object with the constructor
# kwargs the deployment passes to its chat model class.
# J1_TEXT_LLM_LANGCHAIN_CONFIG={"class":"ChatOpenAI","model":"gpt-4o-mini"}

# Vision LLM (required when visual enrichment is enabled)
J1_VISION_LLM_PROVIDER=openai_compat
J1_VISION_LLM_BASE_URL=
J1_VISION_LLM_API_KEY=
J1_VISION_LLM_MODEL=
J1_VISION_LLM_TIMEOUT_SECONDS=90
J1_VISION_LLM_MAX_RETRIES=3
J1_VISION_LLM_TEMPERATURE=0.1
J1_VISION_LLM_MAX_OUTPUT_TOKENS=4096
# Token-budget enforcement — see TEXT comments above.
# J1_VISION_LLM_CONTEXT_WINDOW_TOKENS=8192
# J1_VISION_LLM_SAFETY_MARGIN_TOKENS=256
# J1_VISION_LLM_LANGCHAIN_CONFIG={...}

# Embedding model (required when RAGAnything compiler / retrieval is selected)
J1_EMBEDDING_PROVIDER=openai_compat
J1_EMBEDDING_BASE_URL=
J1_EMBEDDING_API_KEY=
J1_EMBEDDING_MODEL=
J1_EMBEDDING_DIM=1024
J1_EMBEDDING_MAX_TOKENS=8192
J1_EMBEDDING_BATCH_SIZE=32
J1_EMBEDDING_TIMEOUT_SECONDS=60
J1_EMBEDDING_MAX_RETRIES=3
# J1_EMBEDDING_LANGCHAIN_CONFIG={...}
#
# LightRAG-internal watchdog timeouts. Read directly by the
# `lightrag` package from the process env (NOT through J1 settings).
# LightRAG's per-task ceiling is `EMBEDDING_TIMEOUT * 2`; at the 30s
# default that's a 60s cap which can trip on cold-start LM Studio
# embedding calls. Raise both when running RAGAnything against a
# slow / cold local model.
# EMBEDDING_TIMEOUT=180
# LLM_TIMEOUT=300

# ---- FAST LLM role (Phase B, optional) ----------------------------
# Cheap / structured-output role for the adaptive ingestion planner
# and similar short, deterministic tasks (document classification,
# heading normalisation, light metadata). Reuses the same provider
# adapter as text — typical setups point both `J1_TEXT_LLM_BASE_URL`
# and `J1_FAST_LLM_BASE_URL` at the same endpoint with just a
# different `J1_FAST_LLM_MODEL`. Leave the URL empty to disable;
# deterministic planning still works without FAST configured.
J1_FAST_LLM_PROVIDER=openai_compat
J1_FAST_LLM_BASE_URL=
J1_FAST_LLM_API_KEY=
J1_FAST_LLM_MODEL=
J1_FAST_LLM_TIMEOUT_SECONDS=15
J1_FAST_LLM_MAX_RETRIES=1
J1_FAST_LLM_TEMPERATURE=0.0
J1_FAST_LLM_MAX_OUTPUT_TOKENS=512
# Token-budget enforcement — see TEXT comments above.
# J1_FAST_LLM_CONTEXT_WINDOW_TOKENS=4096
# J1_FAST_LLM_SAFETY_MARGIN_TOKENS=256
# J1_FAST_LLM_LANGCHAIN_CONFIG={...}

# ---- LightRAG throughput knobs (vendor env vars) -------------------
# These are LightRAG-internal settings (NOT `J1_*` prefixed). Tune
# when running against a single shared LLM endpoint such as a local
# LM Studio instance — the defaults assume a multi-tenant inference
# server with headroom.
#
# `MAX_ASYNC=4` (vendor default): how many concurrent LLM calls
# LightRAG may have in-flight per worker. A single LM Studio process
# can only run one generation at a time, so on a laptop set this to
# 1 — otherwise N requests just queue and wall-clock per call scales
# with N.
MAX_ASYNC=1
#
# `MAX_GLEANING=1` (vendor default): how many extra "continue
# extraction" passes LightRAG runs per chunk to improve recall. Each
# extra pass is a full LLM call. Set to 0 on slow local models when
# finishing inside the per-call timeout matters more than recall.
MAX_GLEANING=0

# ---- Adaptive ingestion planning ----------------------------------
# When enabled, each document is profiled (deterministic checks) and
# run through a planner that decides which pipeline stages to attempt
# and emits a `plan.generated` progress event the FE's run-detail
# page consumes. Caller-supplied `compilerKind` / `enricherKind` /
# `graphBuilderKind` / `indexerKind` always override planner
# decisions (caller wins). Default `true` for the dev stack so the
# Execution Console shows a populated execution plan immediately;
# flip to `false` to skip profiling and run in the legacy
# "kind is None → skip" mode. Read by the dev API entrypoint at
# `deploy/dev/api.py` — production deployments wire planner usage at
# their own bootstrap layer.
J1_INGEST_PLANNER_ENABLED=true
# Default policy when callers don't override per-job:
#   auto | cost_saving | balanced | high_accuracy | force_full | text_only
J1_INGEST_DEFAULT_POLICY=auto

# ---- Planning Report stage ----------------------------------------
# The Planning Report surfaces — through `GET /ingestion-runs/{id}/
# planning` and the Run-Detail "Planning Report" tab — the planner's
# decisions in a richer shape than the raw `IngestPlan` carried by
# `/ingestion-runs/{id}/plan`. Includes the rule-based assessment, a
# small content digest sampled from the parsed-content manifest, and
# (when enabled) a feature-flagged LLM-assisted recommendation.
#
# Default behaviour is rule-based only. The LLM-assisted path is
# OFF by default and requires opting in via J1_INGEST_PLAN_MODE
# (preferred) or J1_LLM_PLANNING_ENABLED (legacy, still honored).
# When enabled, the LLM planner sees only a sampled digest of the
# parsed content (capped via the two MAX_* envs below) — never the
# full raw document.
#
# `J1_INGEST_PLAN_MODE` is the operator-facing knob the FE Planning
# Report tab renders as a "Planner mode" badge. Accepted values:
#   rule_based  — deterministic only (default)
#   llm         — LLM-assisted (replaces deprecated
#                  J1_LLM_PLANNING_ENABLED=true)
#   hybrid      — both run; LLM result wins on agreement, rule-based
#                  is the safety net on disagreement / failure
# J1_INGEST_PLAN_MODE=rule_based
# J1_PLANNING_ENABLED=true
# J1_LLM_PLANNING_ENABLED=false
# Named LLM role used when LLM-assisted planning is enabled. The
# composition root resolves the name to a configured role (e.g. the
# FAST or PREMIUM role, or a deployment-registered profile).
# J1_PLANNING_MODEL_PROFILE=fast_planner
# Privacy boundary — caps for the digest fed to the LLM planner.
# J1_PLANNING_MAX_SAMPLE_BLOCKS=20
# J1_PLANNING_MAX_PREVIEW_CHARS=300
# When true (default), failure of the LLM-assisted planning path
# leaves the rule-based decision in place and continues the run.
# Set to false only when planning is treated as a hard gate.
# J1_PLANNING_FAIL_OPEN=true

# ---- Domain packs --------------------------------------------------
# Domain packs extend the post-compile planner with domain-aware
# decisions (e.g. Civil Engineering recognises BOQ / inspection
# reports / drawings and tunes planning accordingly). The generic
# baseline is always present; packs only get selected when the
# detector clears `J1_DOMAIN_DETECTION_MIN_CONFIDENCE`.
#
# Selection precedence: user upload override → workspace default →
# auto-detect → fallback to `general`.
# J1_DOMAIN_PACKS_ENABLED=true
# J1_DEFAULT_DOMAIN=general
# J1_DOMAIN_DETECTION_ENABLED=true
# J1_DOMAIN_DETECTION_MIN_CONFIDENCE=0.65
# Comma-separated allow-list of domains operators may force per-run
# or via workspace default. Domains outside this set are ignored
# even when configured (defence-in-depth against typos).
# J1_ALLOWED_DOMAIN_OVERRIDES=general,civil_engineering
# Workspace / project default domain — applied when no upload-time
# override is provided. `general` keeps the legacy generic flow.
# J1_WORKSPACE_DEFAULT_DOMAIN=general

# ---- Temporal search attributes ------------------------------------
# When true, the workflow upserts `J1IngestStage` and `J1IngestMode`
# so operators can filter workflows by stage / mode in the Temporal
# UI. The dev compose stack registers both attributes automatically
# via the `temporal-init` one-shot service (`api` and `worker` wait
# on its completion), so the default for the dev stack is `true`.
#
# If you're running the framework against a Temporal cluster you
# manage yourself, register the attributes first or this flag will
# cause `BadSearchAttributes` on every workflow activation:
#
#   temporal operator search-attribute create \
#     --namespace default --name J1IngestStage --type Keyword
#   temporal operator search-attribute create \
#     --namespace default --name J1IngestMode --type Keyword
#
# Then leave the value below as-is, or override to `false` to opt out.
J1_TEMPORAL_SEARCH_ATTRIBUTES_ENABLED=true