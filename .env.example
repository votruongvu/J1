# Local-development environment for the J1 stack.
#
# Copy to `.env` (which is git-ignored) before running `docker compose up`:
#
#     cp .env.example .env
#
# Variable names match the framework's existing `J1_*` convention — all
# settings live in one namespace so it's clear what comes from J1 vs.
# the deployment. Do not put real secrets here; this file is committed.

# ---- Workspace ------------------------------------------------------
# Where every project's data lives on disk. Inside the container the
# workspace is mounted at this path; on the host it lives in the
# named Docker volume `j1_workspace` (see deploy/dev/docker-compose.yml).
J1_DATA_ROOT=/var/lib/j1

# ---- Temporal -------------------------------------------------------
# Temporal connection used by both the API (workflow start / query)
# and the worker (workflow + activity registration).
J1_TEMPORAL_TARGET=temporal:7233
J1_TEMPORAL_NAMESPACE=default
J1_TEMPORAL_TASK_QUEUE=j1-processing
# J1_TEMPORAL_TLS=false
# J1_TEMPORAL_API_KEY=...

# ---- API service ----------------------------------------------------
# Port the FastAPI app binds to inside the container. Mapped to the
# same host port by the compose file.
J1_API_PORT=8000

# ---- Worker service -------------------------------------------------
# Maximum number of activities a single worker process runs in
# parallel. Tune to taste; defaults to a small number for laptop use.
J1_WORKER_MAX_CONCURRENT_ACTIVITIES=5

# ---- Auth (optional — empty disables authentication) ----------------
# When unset, the API runs in anonymous mode (every request gets the
# anonymous SecurityContext). For local development that's fine.
# To require auth, set to a JSON object keyed by token:
#
#   J1_AUTH_API_KEYS={"kb_local_001":{"subject":"dev","tenant_id":"acme","scopes":["kb:read","kb:search","kb:answer","kb:ingest","kb:admin","kb:audit.read"]}}
#
# Or point at a JSON file:
#
#   J1_AUTH_API_KEYS_FILE=/run/secrets/j1-api-keys.json
#
# Never put real keys in this committed file.

# ---- Webhooks (optional) -------------------------------------------
# Inline list, or a path to a JSON file with the same shape:
# J1_WEBHOOK_SUBSCRIPTIONS_FILE=/run/secrets/j1-webhooks.json

# ---- Event publisher (optional) ------------------------------------
# Defaults to `noop` — enable `bus` to fan events to webhook subscribers.
# J1_EVENT_PUBLISHER_TYPE=bus

# ---- Processing pipeline selection ---------------------------------
# Compiler → Enrich → Graph → Persist. Each stage is selected
# independently. Built-in selections:
#
#   mock         — bundled deterministic mock adapters; no vendor
#                  deps, no LLM credentials required. Used by the dev
#                  Docker stack so `docker compose up` runs a real
#                  workflow end-to-end out of the box.
#   raganything  — production-grade RAGAnything provider; requires
#                  `pip install j1[raganything]` AND the J1_TEXT_LLM_*
#                  / J1_EMBEDDING_* (and J1_VISION_LLM_* if visual
#                  enrichment is on) env vars below.
#   graphify     — alternative graph provider (graph stage only);
#                  also requires J1_GRAPHIFY_ENABLED=true.
#
# Defaults below run a deterministic smoke pipeline. Flip to
# `raganything` once you've configured an LLM endpoint.
J1_DEFAULT_COMPILER=mock
J1_DEFAULT_GRAPH_PROVIDER=mock
J1_DEFAULT_RETRIEVAL_PROVIDER=mock

# Production-grade selections (commented out — uncomment + set the
# LLM env vars further down to drive real processing):
# J1_DEFAULT_COMPILER=raganything
# J1_DEFAULT_GRAPH_PROVIDER=raganything
# J1_DEFAULT_RETRIEVAL_PROVIDER=raganything

# ---- Enrichment ----------------------------------------------------
# Confidence-driven enrichment between Compiler and Graph stages.
# Disabled by default in the dev stack — there are no bundled mock
# enrichers. To run enrichment, register your own enricher map in a
# forked worker entrypoint and set J1_ENRICH_ENABLED=true.
# Visual modalities (images / diagrams / scanned pages) additionally
# require the vision LLM role to be configured below.
J1_ENRICH_ENABLED=false
J1_ENRICH_CONFIDENCE_THRESHOLD=0.75
J1_ENRICH_IMAGES=true
J1_ENRICH_TABLES=true
J1_ENRICH_DIAGRAMS=true
J1_ENRICH_SCANNED_PAGES=true

# ---- RAGAnything provider ------------------------------------------
J1_RAGANYTHING_MODE=local
J1_RAGANYTHING_WORKDIR=./data/raganything
# Inferred from WORKDIR if unset:
# J1_RAGANYTHING_STORAGE_DIR=./data/raganything/storage
# J1_RAGANYTHING_CACHE_DIR=./data/raganything/cache
#
# MinerU parse method passed to process_document_complete().
# "auto" (default) uses the hybrid-auto-engine which requires local
# torch + mineru[pipeline] and libxcb1 (see Dockerfile).
# Use "vlm-http-client" for container/cloud deployments that have VLM
# API access but no local GPU — avoids the torch/libxcb dependency.
# J1_RAGANYTHING_PARSE_METHOD=vlm-http-client
#
# Processor hooks — point at deployment-supplied callables that drive
# the actual `raganything` library. When set, the adapter loads them
# via the safe class-loader (allowlisted to langchain*, j1.*, plus
# any prefix you register via j1.register_trusted_prefix).
# Format: "module.path:callable_name" or "module.path.callable_name".
# J1_RAGANYTHING_COMPILER_PROCESSOR=mypkg.processors:compile_doc
# J1_RAGANYTHING_GRAPH_PROCESSOR=mypkg.processors:build_graph
# J1_RAGANYTHING_RETRIEVAL_PROCESSOR=mypkg.processors:query
#
# LibreOffice pre-conversion (broad document-format coverage).
# RAGAnything / mineru parses PDF + modern OOXML (.docx/.xlsx/.pptx)
# + images natively, but cannot parse legacy binary office formats
# (.doc/.xls/.ppt), OpenDocument (.odt/.ods/.odp), Rich Text (.rtf),
# Apple iWork (.pages/.numbers/.key), or Microsoft Works (.wps).
# For those, the bridge calls `soffice --headless --convert-to pdf
# <source>` and feeds the resulting PDF to raganything.
#
# Comma-separated extension list (with or without leading dot).
# Set empty to disable conversion entirely. Default covers the
# common legacy / non-OOXML formats:
# J1_RAGANYTHING_PDF_CONVERT_EXTENSIONS=.doc,.xls,.ppt,.rtf,.odt,.ods,.odp,.pages,.numbers,.key,.wps
#
# LibreOffice headless binary. Default `soffice`; some distros use
# `libreoffice` as the user-facing alias. Resolved via $PATH.
# J1_RAGANYTHING_LIBREOFFICE_BINARY=soffice
#
# Per-conversion timeout (seconds). LibreOffice can be slow on first
# launch (font cache rebuild). Default 120s.
# J1_RAGANYTHING_LIBREOFFICE_TIMEOUT_SECONDS=120

# ---- Graphify provider (optional alternative graph builder) --------
J1_GRAPHIFY_ENABLED=false
J1_GRAPHIFY_MODE=cli
J1_GRAPHIFY_COMMAND=graphify
J1_GRAPHIFY_WORKDIR=./data/graphify
# Processor hook (same format as RAGAnything):
# J1_GRAPHIFY_GRAPH_PROCESSOR=mypkg.processors:graphify_build

# ---- LLM roles (text / vision / embedding) -------------------------
# Three roles, configured independently. `openai_compat` works with
# any provider that exposes the OpenAI REST surface (vLLM, Ollama,
# Together, Azure, DashScope, etc.). For LangChain, set the role's
# *_PROVIDER to `langchain` and supply a JSON config — see
# docs/architecture.md § "LLM provider layer".

# Text LLM
J1_TEXT_LLM_PROVIDER=openai_compat
J1_TEXT_LLM_BASE_URL=
J1_TEXT_LLM_API_KEY=
J1_TEXT_LLM_MODEL=
J1_TEXT_LLM_TIMEOUT_SECONDS=60
J1_TEXT_LLM_MAX_RETRIES=3
J1_TEXT_LLM_TEMPERATURE=0.2
J1_TEXT_LLM_MAX_OUTPUT_TOKENS=4096
# For LangChain: provide an inline JSON object with the constructor
# kwargs the deployment passes to its chat model class.
# J1_TEXT_LLM_LANGCHAIN_CONFIG={"class":"ChatOpenAI","model":"gpt-4o-mini"}

# Vision LLM (required when visual enrichment is enabled)
J1_VISION_LLM_PROVIDER=openai_compat
J1_VISION_LLM_BASE_URL=
J1_VISION_LLM_API_KEY=
J1_VISION_LLM_MODEL=
J1_VISION_LLM_TIMEOUT_SECONDS=90
J1_VISION_LLM_MAX_RETRIES=3
J1_VISION_LLM_TEMPERATURE=0.1
J1_VISION_LLM_MAX_OUTPUT_TOKENS=4096
# J1_VISION_LLM_LANGCHAIN_CONFIG={...}

# Embedding model (required when RAGAnything compiler / retrieval is selected)
J1_EMBEDDING_PROVIDER=openai_compat
J1_EMBEDDING_BASE_URL=
J1_EMBEDDING_API_KEY=
J1_EMBEDDING_MODEL=
J1_EMBEDDING_DIM=1024
J1_EMBEDDING_MAX_TOKENS=8192
J1_EMBEDDING_BATCH_SIZE=32
J1_EMBEDDING_TIMEOUT_SECONDS=60
J1_EMBEDDING_MAX_RETRIES=3
# J1_EMBEDDING_LANGCHAIN_CONFIG={...}
